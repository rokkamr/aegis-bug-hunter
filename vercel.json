{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/signup",
      "dest": "/api/auth/signup.js"
    },
    {
      "src": "/api/auth/login",
      "dest": "/api/auth/login.js"
    },
    {
      "src": "/api/projects",
      "dest": "/api/projects.js"
    },
    {
      "src": "/api/test-cases",
      "dest": "/api/test-cases.js"
    },
    {
      "src": "/api/bugs",
      "dest": "/api/bugs.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
